<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hotelbooking.controller.DashboardController"
            style="-fx-background-color: #f0f4f8;">

    <!-- TOP NAV BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="Hotel Booking System"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="New Booking" onAction="#openBooking"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-font-size: 13; -fx-cursor: hand; -fx-padding: 8 16;"/>
            <Button text="Refresh" onAction="#handleRefresh"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                           -fx-font-size: 13; -fx-cursor: hand; -fx-padding: 8 16;"/>
            <Button text="Reset All Data" onAction="#handleReset"
                     style="-fx-background-color: #8e44ad; -fx-text-fill: white;
               -fx-font-size: 13; -fx-cursor: hand; -fx-padding: 8 16;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-font-size: 13; -fx-cursor: hand; -fx-padding: 8 16;"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" style="-fx-padding: 30;">

            <!-- STATS ROW -->
            <HBox spacing="20">
                <VBox alignment="CENTER" spacing="5"
                      style="-fx-background-color: #3498db; -fx-padding: 20;
                             -fx-pref-width: 180; -fx-background-radius: 10;">
                    <Label fx:id="totalRoomsLabel" text="0"
                           style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Total Rooms"
                           style="-fx-text-fill: white; -fx-font-size: 13;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="5"
                      style="-fx-background-color: #2ecc71; -fx-padding: 20;
                             -fx-pref-width: 180; -fx-background-radius: 10;">
                    <Label fx:id="availableRoomsLabel" text="0"
                           style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Available Rooms"
                           style="-fx-text-fill: white; -fx-font-size: 13;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="5"
                      style="-fx-background-color: #e74c3c; -fx-padding: 20;
                             -fx-pref-width: 180; -fx-background-radius: 10;">
                    <Label fx:id="occupiedRoomsLabel" text="0"
                           style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Occupied Rooms"
                           style="-fx-text-fill: white; -fx-font-size: 13;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="5"
                      style="-fx-background-color: #f39c12; -fx-padding: 20;
                             -fx-pref-width: 180; -fx-background-radius: 10;">
                    <Label fx:id="totalBookingsLabel" text="0"
                           style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Total Bookings"
                           style="-fx-text-fill: white; -fx-font-size: 13;"/>
                </VBox>
            </HBox>

            <!-- TABS -->
            <TabPane VBox.vgrow="ALWAYS">

                <!-- ROOMS TAB -->
                <Tab text="Rooms" closable="false">
                    <VBox spacing="10">
                        <Label text="Room Overview"
                               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <TableView fx:id="roomsTable" prefHeight="250">
                            <columns>
                                <TableColumn fx:id="roomNumberCol" text="Room No." prefWidth="100"/>
                                <TableColumn fx:id="roomTypeCol"   text="Type"     prefWidth="150"/>
                                <TableColumn fx:id="roomPriceCol"  text="Price/Night" prefWidth="150"/>
                                <TableColumn fx:id="roomStatusCol" text="Status"   prefWidth="150"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- BOOKINGS TAB -->
              <Tab text="Bookings" closable="false">
              <VBox spacing="10">
                     <Label text="All Bookings"
                            style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                     <TableView fx:id="bookingsTable" prefHeight="250">
                     <columns>
                            <TableColumn fx:id="bookingIdCol"      text="ID"         prefWidth="50"/>
                            <TableColumn fx:id="bookingGuestCol"   text="Guest"      prefWidth="140"/>
                            <TableColumn fx:id="bookingRoomCol"    text="Room"       prefWidth="80"/>
                            <TableColumn fx:id="bookingCheckInCol"  text="Check-In"  prefWidth="110"/>
                            <TableColumn fx:id="bookingCheckOutCol" text="Check-Out" prefWidth="110"/>
                            <TableColumn fx:id="bookingStatusCol"  text="Status"     prefWidth="100"/>
                     </columns>
                     </TableView>
                     <HBox spacing="10">
                     <Button text="Cancel Selected Booking" onAction="#handleCancelBooking"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                   -fx-font-size: 13; -fx-padding: 8 16; -fx-cursor: hand;"/>
                     <Label fx:id="cancelStatusLabel" style="-fx-font-size: 13;"/>
                     </HBox>
              </VBox>
              </Tab>

            </TabPane>

        </VBox>
    </center>

</BorderPane>